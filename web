    // ---- تهريب HTML آمن (تم إصلاحه: كان يستبدل الرموز بأحرفها الحرفية بدل كيانات HTML) ----
    function escapeHtml(str) {
        if (!str) return "";
        return String(str)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

