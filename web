    function buildPostCard(post) {
        const card = document.createElement('div');
        card.className = 'post-card';
        card.id = 'post-' + post.postId;
        card.dataset.userId = post.userId || '';
        card.dataset.postType = post.type || '';

        let mediaHtml = "";
        if (post.type === 'image' && post.mediaUrl) {
            mediaHtml = `<img class="post-media" src="${escapeHtml(post.mediaUrl)}" loading="lazy">`;
        } else if (post.type === 'video' && post.mediaUrl) {
            mediaHtml = `<video class="post-media" src="${escapeHtml(post.mediaUrl)}" controls></video>`;
        } else if (post.type === 'text') {
            mediaHtml = `<div class="post-text-only">${escapeHtml(post.caption)}</div>`;
        }

        const captionHtml = (post.type !== 'text' && post.caption)
            ? `<div class="post-caption">${escapeHtml(post.caption)}</div>`
            : "";

        // زر النقاط الثلاث (تعديل/حذف) لا يظهر إلا لصاحب المنشور
        const isOwner = currentGmail && post.userId && (post.userId === currentGmail);
        const menuBtnHtml = isOwner
            ? `<button class="post-menu-btn material-icons" onclick="openPostMenu(event, '${post.postId}')" title="خيارات المنشور">more_vert</button>`
            : "";

        card.innerHTML = `
            <div class="post-header">
                <div class="avatar-wrap">
                    ${avatarHtml(post.userPhoto, 'avatar avatar-sm')}
                </div>
                <div class="post-header-info">
                    <div class="post-username">${escapeHtml(post.username)}</div>
                    <div class="post-time">${formatTime(post.date)}</div>
                </div>
                ${menuBtnHtml}
            </div>
            ${captionHtml}
            ${mediaHtml}
            <div class="post-actions">
                <button class="post-action-btn like-btn ${post.likedByMe ? 'liked' : ''}" onclick="toggleLike('${post.postId}', this)">
                    <span class="material-icons">${post.likedByMe ? 'favorite' : 'favorite_border'}</span>
                    <span class="like-count">${post.likesCount}</span>
                </button>
                <button class="post-action-btn" onclick="openComments('${post.postId}')">
                    <span class="material-icons">chat_bubble_outline</span>
                    <span class="comment-count">${post.commentsCount}</span>
                </button>
            </div>
        `;

        return card;
    }

    async function toggleLike(postId, btnEl) {
        // تحديث تفاؤلي فوري للواجهة
        const isLiked = btnEl.classList.contains('liked');
        const iconEl = btnEl.querySelector('.material-icons');
        const countEl = btnEl.querySelector('.like-count');
        let count = parseInt(countEl.innerText, 10) || 0;

        if (isLiked) {
            btnEl.classList.remove('liked');
            iconEl.innerText = 'favorite_border';
            countEl.innerText = Math.max(0, count - 1);
        } else {
            btnEl.classList.add('liked');
            iconEl.innerText = 'favorite';
            countEl.innerText = count + 1;
        }

        const response = await makeRequest({
            action: "toggle_like",
            postId: postId,
            gmail: currentGmail
        }, false);

        if (response && response.status === "success") {
            countEl.innerText = response.likesCount;
            if (response.liked) {
                btnEl.classList.add('liked');
                iconEl.innerText = 'favorite';
            } else {
                btnEl.classList.remove('liked');
                iconEl.innerText = 'favorite_border';
            }
        } else {
            // تراجع عن التحديث في حال فشل الطلب
            showToast("تعذر تسجيل الإعجاب");
            loadPosts(true);
        }
    }

