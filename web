        field.value = "";

        const response = await makeRequest({
            action: "add_comment",
            postId: activeCommentsPostId,
            gmail: currentGmail,
            username: currentUser,
            comment: text
        }, false);

        if (response && response.status === "success") {
            const container = document.getElementById('comments-list');
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) emptyState.remove();

            container.appendChild(buildCommentItem(response.comment));
            container.scrollTop = container.scrollHeight;

            // تحديث عدد التعليقات في بطاقة المنشور إن كانت ظاهرة في القائمة
            const postCard = document.getElementById('post-' + activeCommentsPostId);
            if (postCard) {
                const countEl = postCard.querySelector('.comment-count');
                if (countEl) countEl.innerText = response.commentsCount;
            }
        } else {
            showToast("تعذر إضافة التعليق");
        }
    }
</script>
</body>
</html>
