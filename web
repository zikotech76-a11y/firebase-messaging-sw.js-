                username: response.post.username,
                userPhoto: response.post.userPhoto,
                type: response.post.type,
                mediaUrl: response.post.mediaUrl,
                caption: response.post.caption,
                likesCount: 0,
                commentsCount: 0,
                date: response.post.date,
                likedByMe: false
            });
            container.insertBefore(card, container.firstChild);
            postsOffset += 1;
        } else {
            const debugMsg = response && response.debug ? (": " + response.debug) : "";
            showToast("تعذر نشر المنشور، حاول مجددًا" + debugMsg);
            console.error("create_post failed:", response);
