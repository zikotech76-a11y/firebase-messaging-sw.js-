    function handleMediaSelect(event, type) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const result = e.target.result;
            selectedMediaBase64 = result.split(',')[1];
            selectedMediaMime = file.type;

            if (type === 'image') {
                const img = document.getElementById('media-preview-img');
                img.src = result;
                img.style.display = 'block';
            } else {
                const vid = document.getElementById('media-preview-video');
                vid.src = result;
                vid.style.display = 'block';
            }
        };
        reader.readAsDataURL(file);
    }

    async function submitPost() {
        const caption = document.getElementById('post-caption-input').value.trim();

        if (selectedPostType === 'text' && !caption) {
            showToast("الرجاء كتابة نص للمنشور");
            return;
