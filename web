    function closeChat() {
        activeChatPartner = "";
        activeChatPartnerPhoto = "";
        if (chatAvatarInterval) { clearInterval(chatAvatarInterval); chatAvatarInterval = null; }
        // إلغاء أي تسجيل صوتي جارٍ عند مغادرة المحادثة
        cancelVoiceRecording();
        navigateTo('page-home');
    }

    // ============ تحميل الرسائل (نصية + صوتية معًا) ============
    async function loadMessages(isBackground = false) {
        if (!activeChatPartner) return;

        const response = await makeRequest({
            action: "get_conversation_messages",
            sender: currentUser,
            receiver: activeChatPartner
        }, !isBackground);

        if (!response) return;

        let combined = [];

        if (Array.isArray(response.messages)) {
            response.messages.forEach(m => combined.push({
                kind: 'text',
                id: m.id || '',
                sender: m.sender,
                receiver: m.receiver,
                message: m.message,
                time: m.time
            }));
        }

        if (Array.isArray(response.audioMessages)) {
            response.audioMessages.forEach(a => combined.push({
                kind: 'audio',
                id: a.audioId,
                sender: a.senderId,
                receiver: a.receiverId,
                audioUrl: a.audioUrl,
                duration: a.duration,
                time: a.timestamp
            }));
        }

        const totalCount = combined.length;
        if (totalCount === lastMessageCount) return;
        lastMessageCount = totalCount;

        combined.sort((a, b) => new Date(a.time) - new Date(b.time));

        const container = document.getElementById('chat-messages-container');
        container.innerHTML = "";

        combined.forEach(item => {
            const isSent = item.sender === currentUser;
            const wrapper = document.createElement('div');
            wrapper.className = 'msg-wrapper ' + (isSent ? 'sent' : 'received');
            wrapper.dataset.msgId = item.id;
            wrapper.dataset.isAudio = item.kind === 'audio' ? 'true' : 'false';
            wrapper.dataset.sender = item.sender;

            if (item.kind === 'text') {
                wrapper.innerHTML = `<div class="msg-bubble">${escapeHtml(item.message)}</div>`;
            } else {
                wrapper.innerHTML = `
                    <div class="msg-bubble audio-msg-bubble">
                        <button class="audio-play-btn material-icons" onclick="toggleAudioMessagePlay(this)">play_arrow</button>
                        <div class="audio-progress-track"><div class="audio-progress-fill"></div></div>
                        <span class="audio-duration">${formatDuration(item.duration || 0)}</span>
                        <audio class="hidden-audio-el" src="${escapeHtml(item.audioUrl)}" preload="none"></audio>
                    </div>`;
            }

            attachLongPress(wrapper, item);
            container.appendChild(wrapper);
        });

        container.scrollTop = container.scrollHeight;
    }

    async function handleSendMessage() {
        const field = document.getElementById('chat-input-field');
        const text = field.value.trim();
        if (!text || !activeChatPartner) return;

        field.value = "";

        const response = await makeRequest({
            action: "send",
            sender: currentUser,
            receiver: activeChatPartner,
            message: text
        }, false);

        if (response && response.status === "sent") {
            lastMessageCount = -1; // إجبار إعادة الرسم لضمان ظهور الرسالة فورًا
            loadMessages(true);
        } else {
            showToast("تعذر إرسال الرسالة");
        }
    }

    // ================= الرسائل الصوتية (Voice Messages) =================
    let mediaRecorder = null;
    let mediaRecorderStream = null;
    let audioChunks = [];
    let recordingStartTime = 0;
    let recordingTimerInterval = null;
    let recordedAudioBlob = null;
    let recordedAudioDuration = 0;
    let voicePreviewAudioEl = null;

    function formatDuration(totalSeconds) {
        const sec = Math.max(0, Math.floor(totalSeconds || 0));
        const m = Math.floor(sec / 60).toString().padStart(2, '0');
        const s = (sec % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
    }

    // إعادة كل عناصر واجهة التسجيل/المعاينة إلى حالتها الافتراضية (يُستخدم عند فتح/إغلاق المحادثة)
    function resetVoiceUiState() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            mediaRecorder.onstop = null;
            try { mediaRecorder.stop(); } catch (e) {}
        }
        if (mediaRecorderStream) {
            mediaRecorderStream.getTracks().forEach(t => t.stop());
            mediaRecorderStream = null;
        }
        if (recordingTimerInterval) clearInterval(recordingTimerInterval);
        if (voicePreviewAudioEl) { voicePreviewAudioEl.pause(); voicePreviewAudioEl = null; }

        recordedAudioBlob = null;
        document.getElementById('voice-recording-bar').style.display = 'none';
        document.getElementById('voice-preview-bar').style.display = 'none';
        document.getElementById('chat-input-bar').style.display = 'flex';
    }

    // ---- اختيار أول صيغة تسجيل مدعومة فعليًا في هذا المتصفح/WebView ----
    // هذا يمنع فشل "new MediaRecorder(stream)" بصمت في بعض بيئات Android WebView
    // التي لا تدعم الصيغة الافتراضية (audio/webm) دون تحديد صريح.
    function getSupportedAudioMimeType() {
        const candidates = [
            'audio/webm;codecs=opus',
            'audio/webm',
            'audio/mp4',
            'audio/aac',
            'audio/ogg;codecs=opus',
            'audio/3gpp'
        ];
        if (typeof MediaRecorder === 'undefined' || !MediaRecorder.isTypeSupported) {
            return null; // سنترك المتصفح يختار الافتراضي إن كانت isTypeSupported غير متوفرة أصلاً
        }
        for (const type of candidates) {
            if (MediaRecorder.isTypeSupported(type)) return type;
        }
        return null;
    }

    // ---- فحص حالة صلاحية الميكروفون قبل المحاولة (إن كانت Permissions API مدعومة) ----
    // بعض بيئات WebView تدعم Permissions API جزئيًا فقط، لذا هذا فحص إضافي غير حاسم
    // ولا نمنع المحاولة إذا فشل أو لم يكن مدعومًا - فقط نضيفه للمعلومات التشخيصية.
    async function queryMicPermissionState() {
        try {
            if (navigator.permissions && navigator.permissions.query) {
                const status = await navigator.permissions.query({ name: 'microphone' });
                return status.state; // 'granted' | 'denied' | 'prompt'
            }
        } catch (e) {
            return 'unsupported (' + e.message + ')';
        }
        return 'unsupported (Permissions API not available)';
    }

    async function startVoiceRecording() {
        // ===== فحص 1: هل الصفحة تعمل ضمن سياق آمن (HTTPS)؟ =====
        // getUserMedia يُرفض دائمًا (بصمت أحيانًا) خارج localhost/HTTPS.
        if (window.isSecureContext === false) {
            openMicDiagModal(
                "يجب فتح التطبيق عبر HTTPS لاستخدام الميكروفون.",
                "isSecureContext: false\nlocation: " + window.location.href
            );
            return;
        }

        // ===== فحص 2: هل الـ API موجودة أصلاً في هذه البيئة (متصفح/WebView)؟ =====
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            openMicDiagModal(
                "getUserMedia غير متوفرة في هذه البيئة إطلاقًا. هذا يعني أن مكوّن عرض الصفحة (WebView) داخل التطبيق لا يوفر واجهة الوسائط أصلاً، بغض النظر عن أي صلاحية.",
                "navigator.mediaDevices: " + (typeof navigator.mediaDevices) +
                "\nuserAgent: " + navigator.userAgent
            );
            return;
        }

        if (typeof MediaRecorder === 'undefined') {
            openMicDiagModal(
                "هذه البيئة لا تدعم تسجيل الصوت (MediaRecorder غير متوفر).",
                "window.MediaRecorder: undefined\nuserAgent: " + navigator.userAgent
            );
            return;
        }

        const permState = await queryMicPermissionState();

        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorderStream = stream;
            audioChunks = [];

            // اختيار صيغة مدعومة فعليًا بدل الاعتماد على الافتراضي فقط
            const supportedMime = getSupportedAudioMimeType();
            try {
                mediaRecorder = supportedMime
                    ? new MediaRecorder(stream, { mimeType: supportedMime })
                    : new MediaRecorder(stream);
            } catch (recorderErr) {
                // فشل إنشاء MediaRecorder نفسه (نادر) - نوقف المسارات ونعرض رسالة دقيقة
                stream.getTracks().forEach(t => t.stop());
                mediaRecorderStream = null;
                openMicDiagModal(
                    "تم منح الوصول للميكروفون، لكن تعذر إنشاء مسجل الصوت (MediaRecorder) في هذا الجهاز.",
                    "MediaRecorder constructor error: " + recorderErr.name + " - " + recorderErr.message +
                    "\nsupportedMime tried: " + (supportedMime || "(default)") +
                    "\npermissions.query state: " + permState
                );
                return;
            }

            mediaRecorder.ondataavailable = (e) => {
                if (e.data && e.data.size > 0) audioChunks.push(e.data);
            };

            mediaRecorder.onstop = () => {
                stream.getTracks().forEach(t => t.stop());
                recordedAudioBlob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
                recordedAudioDuration = Math.round((Date.now() - recordingStartTime) / 1000);
                showVoicePreview();
            };

            mediaRecorder.start();
            recordingStartTime = Date.now();

            document.getElementById('chat-input-bar').style.display = 'none';
            document.getElementById('voice-preview-bar').style.display = 'none';
            document.getElementById('voice-recording-bar').style.display = 'flex';
            document.getElementById('recording-timer').innerText = "00:00";

            if (recordingTimerInterval) clearInterval(recordingTimerInterval);
            recordingTimerInterval = setInterval(() => {
                const elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
                document.getElementById('recording-timer').innerText = formatDuration(elapsed);
            }, 500);

        } catch (err) {
            // ===== رسائل خطأ دقيقة حسب نوع الاستثناء الفعلي، معروضة في نافذة تشخيص كاملة =====
            // (وليس toast فقط، لأن الـ toast يختفي بسرعة ولا يمكن نسخه لإرساله للدعم الفني)
            console.error("getUserMedia error:", err.name, err.message, err);

            let summary;
            if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
                summary = "تم رفض إذن الميكروفون من قِبل مكوّن عرض الصفحة (WebView) داخل التطبيق نفسه، وليس من نظام أندرويد. صلاحية النظام التي منحتها من الإعدادات لا تُمرَّر تلقائيًا لهذا المكوّن. هذا يحتاج إعدادًا من داخل منصة بناء التطبيق (AppCreator24) نفسها، ولا يمكن حله من كود الصفحة.";
            } else if (err.name === 'NotFoundError' || err.name === 'DevicesNotFoundError') {
                summary = "لم يتم العثور على أي ميكروفون متاح لهذا التطبيق على الجهاز.";
            } else if (err.name === 'NotReadableError' || err.name === 'TrackStartError') {
                summary = "الميكروفون قيد الاستخدام من تطبيق آخر حاليًا، أو هناك مشكلة في الهاردوير.";
            } else if (err.name === 'SecurityError') {
                summary = "تعذر الوصول للميكروفون بسبب سياق أمني غير مسموح به (تحقق من أن الصفحة تُحمَّل عبر HTTPS).";
            } else if (err.name === 'AbortError') {
                summary = "تم إلغاء طلب الوصول للميكروفون قبل اكتماله.";
            } else {
                summary = "تعذر الوصول إلى الميكروفون لسبب غير معروف بدقة.";
            }

            const details =
                "error.name: " + err.name +
                "\nerror.message: " + err.message +
                "\npermissions.query state: " + permState +
                "\nisSecureContext: " + window.isSecureContext +
                "\nlocation: " + window.location.href +
                "\nuserAgent: " + navigator.userAgent;

            openMicDiagModal(summary, details);
        }
    }

    // ---- نافذة تشخيص الميكروفون: تعرض السبب + تفاصيل تقنية قابلة للنسخ لإرسالها لدعم AppCreator24 ----
    function openMicDiagModal(summary, details) {
        document.getElementById('mic-diag-summary').innerText = summary;
        document.getElementById('mic-diag-details').innerText = details;
        document.getElementById('mic-diag-modal').classList.add('active');
    }

    function closeMicDiagModal() {
        document.getElementById('mic-diag-modal').classList.remove('active');
    }

    function copyMicDiagDetails() {
        const summary = document.getElementById('mic-diag-summary').innerText;
        const details = document.getElementById('mic-diag-details').innerText;
        const fullText = summary + "\n\n" + details;

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(fullText).then(() => {
                showToast('تم نسخ التفاصيل، الصقها في رسالة للدعم الفني');
            }).catch(() => {
                showToast('تعذر النسخ التلقائي، انسخ النص يدويًا من الصندوق');
            });
        } else {
            showToast('النسخ التلقائي غير مدعوم هنا، انسخ النص يدويًا من الصندوق');
        }
    }

    function stopVoiceRecording() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            mediaRecorder.stop();
        }
        if (recordingTimerInterval) clearInterval(recordingTimerInterval);
        document.getElementById('voice-recording-bar').style.display = 'none';
    }

    function cancelVoiceRecording() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            mediaRecorder.onstop = null; // منع ظهور شاشة المعاينة بعد الإلغاء
            try { mediaRecorder.stop(); } catch (e) {}
        }
        if (mediaRecorderStream) {
            mediaRecorderStream.getTracks().forEach(t => t.stop());
            mediaRecorderStream = null;
        }
        if (recordingTimerInterval) clearInterval(recordingTimerInterval);
        recordedAudioBlob = null;

        document.getElementById('voice-recording-bar').style.display = 'none';
        document.getElementById('voice-preview-bar').style.display = 'none';
        document.getElementById('chat-input-bar').style.display = 'flex';
    }

    function showVoicePreview() {
        document.getElementById('voice-preview-bar').style.display = 'flex';
        document.getElementById('voice-preview-duration').innerText = formatDuration(recordedAudioDuration);
        document.getElementById('voice-preview-play-btn').innerText = 'play_arrow';
        if (voicePreviewAudioEl) { voicePreviewAudioEl.pause(); voicePreviewAudioEl = null; }
    }

    function deleteVoicePreview() {
        if (voicePreviewAudioEl) { voicePreviewAudioEl.pause(); voicePreviewAudioEl = null; }
        recordedAudioBlob = null;
        document.getElementById('voice-preview-bar').style.display = 'none';
        document.getElementById('chat-input-bar').style.display = 'flex';
    }

    function toggleVoicePreviewPlay() {
        const btn = document.getElementById('voice-preview-play-btn');
        if (!recordedAudioBlob) return;

        if (!voicePreviewAudioEl) {
            voicePreviewAudioEl = new Audio(URL.createObjectURL(recordedAudioBlob));
            voicePreviewAudioEl.onended = () => { btn.innerText = 'play_arrow'; };
        }

        if (voicePreviewAudioEl.paused) {
            voicePreviewAudioEl.play();
            btn.innerText = 'pause';
        } else {
            voicePreviewAudioEl.pause();
            btn.innerText = 'play_arrow';
        }
    }

    async function sendVoiceMessage() {
        if (!recordedAudioBlob || !activeChatPartner) return;

        if (voicePreviewAudioEl) voicePreviewAudioEl.pause();

        const blobToSend = recordedAudioBlob;
        const durationToSend = recordedAudioDuration;

        const reader = new FileReader();
        reader.onload = async function (e) {
            const base64 = e.target.result.split(',')[1];
            const mimeType = blobToSend.type || 'audio/webm';

            const response = await makeRequest({
                action: "send_audio",
                sender: currentUser,
                senderGmail: currentGmail,
                receiver: activeChatPartner,
                audioBase64: base64,
                mimeType: mimeType,
                duration: durationToSend,
                fileName: "voice_" + Date.now()
            });

            if (response && response.status === "success") {
                document.getElementById('voice-preview-bar').style.display = 'none';
                document.getElementById('chat-input-bar').style.display = 'flex';
                recordedAudioBlob = null;
                lastMessageCount = -1;
                loadMessages(true);
            } else {
                const debugMsg = response && response.debug ? (": " + response.debug) : "";
                showToast("تعذر إرسال الرسالة الصوتية" + debugMsg);
                console.error("send_audio failed:", response);
            }
        };
        reader.readAsDataURL(blobToSend);
    }

    // تشغيل/إيقاف رسالة صوتية داخل المحادثة، مع إيقاف أي رسالة صوتية أخرى قيد التشغيل
    function toggleAudioMessagePlay(btn) {
        const bubble = btn.closest('.audio-msg-bubble');
        const audioEl = bubble.querySelector('.hidden-audio-el');
        const fill = bubble.querySelector('.audio-progress-fill');

        document.querySelectorAll('.hidden-audio-el').forEach(el => {
            if (el !== audioEl && !el.paused) {
                el.pause();
                const otherBubble = el.closest('.audio-msg-bubble');
                const otherBtn = otherBubble ? otherBubble.querySelector('.audio-play-btn') : null;
                const otherFill = otherBubble ? otherBubble.querySelector('.audio-progress-fill') : null;
                if (otherBtn) otherBtn.innerText = 'play_arrow';
                if (otherFill) otherFill.style.width = '0%';
            }
        });

        if (audioEl.paused) {
            audioEl.play();
            btn.innerText = 'pause';
            audioEl.ontimeupdate = () => {
                if (audioEl.duration) {
                    fill.style.width = ((audioEl.currentTime / audioEl.duration) * 100) + '%';
                }
            };
            audioEl.onended = () => {
                btn.innerText = 'play_arrow';
                fill.style.width = '0%';
            };
        } else {
            audioEl.pause();
            btn.innerText = 'play_arrow';
        }
    }

    // ================= القائمة السياقية (ضغط مطول على الرسائل) =================
    let longPressTimer = null;
    const LONG_PRESS_MS = 550;
    const LONG_PRESS_MOVE_TOLERANCE = 10;
    let longPressStartX = 0;
    let longPressStartY = 0;

    // ربط أحداث الضغط المطول بعنصر رسالة معيّن (يعمل على اللمس والماوس معًا)
    function attachLongPress(el, item) {
        const start = (e) => {
            const point = e.touches ? e.touches[0] : e;
            longPressStartX = point.clientX;
            longPressStartY = point.clientY;
            clearTimeout(longPressTimer);
            longPressTimer = setTimeout(() => {
                openMessageContextMenu(item, point);
            }, LONG_PRESS_MS);
        };
        const move = (e) => {
            const point = e.touches ? e.touches[0] : e;
            const dx = Math.abs(point.clientX - longPressStartX);
            const dy = Math.abs(point.clientY - longPressStartY);
            if (dx > LONG_PRESS_MOVE_TOLERANCE || dy > LONG_PRESS_MOVE_TOLERANCE) {
                clearTimeout(longPressTimer);
            }
        };
        const cancel = () => { clearTimeout(longPressTimer); };

        el.addEventListener('touchstart', start, { passive: true });
        el.addEventListener('touchmove', move, { passive: true });
        el.addEventListener('touchend', cancel);
        el.addEventListener('touchcancel', cancel);
        el.addEventListener('mousedown', start);
        el.addEventListener('mousemove', move);
        el.addEventListener('mouseup', cancel);
        el.addEventListener('mouseleave', cancel);
        // منع قائمة المتصفح الافتراضية للنسخ عند الضغط المطول على الجوال
        el.addEventListener('contextmenu', (e) => e.preventDefault());
    }

    // يفتح قائمة (نسخ/حذف) فقط إذا كانت الرسالة تخص المستخدم الحالي
    function openMessageContextMenu(item, point) {
        if (item.sender !== currentUser) return;

        const menu = document.getElementById('message-context-menu');
        let html = '';

        if (item.kind === 'text') {
            html += `<button class="context-menu-item" onclick="copyMessageText('${escapeForInlineJs(item.message)}')"><span class="material-icons">content_copy</span> نسخ الرسالة</button>`;
        }

        html += `<button class="context-menu-item context-menu-danger" onclick="confirmDeleteMessage('${escapeForInlineJs(item.id)}', ${item.kind === 'audio'})"><span class="material-icons">delete</span> حذف الرسالة</button>`;

        menu.innerHTML = html;
        positionAndShowContextMenu(menu, point.clientX, point.clientY);
    }

    // يضبط موضع القائمة العائمة بحيث لا تخرج عن حدود الشاشة، ثم يُظهرها
    function positionAndShowContextMenu(menu, x, y) {
        menu.style.left = '0px';
        menu.style.top = '0px';
        menu.style.display = 'block';
        document.getElementById('context-menu-catcher').style.display = 'block';

        requestAnimationFrame(() => {
            const rect = menu.getBoundingClientRect();
            const maxX = window.innerWidth - rect.width - 8;
            const maxY = window.innerHeight - rect.height - 8;
            menu.style.left = Math.max(8, Math.min(x, maxX)) + 'px';
            menu.style.top = Math.max(8, Math.min(y, maxY)) + 'px';
        });
    }

    function closeAllContextMenus() {
        document.getElementById('message-context-menu').style.display = 'none';
        document.getElementById('context-menu-catcher').style.display = 'none';
    }

    // تهريب بسيط للنصوص كي يمكن تمريرها بأمان داخل استدعاء onclick المضمّن
    function escapeForInlineJs(str) {
        return String(str)
            .replace(/\\/g, '\\\\')
            .replace(/'/g, "\\'")
            .replace(/\n/g, '\\n')
            .replace(/\r/g, '');
    }

    function unescapeFromInlineJs(str) {
        return String(str)
            .replace(/\\n/g, '\n')
            .replace(/\\'/g, "'")
            .replace(/\\\\/g, '\\');
    }

    function copyMessageText(escapedText) {
        closeAllContextMenus();
        const text = unescapeFromInlineJs(escapedText);
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(() => {
                showToast('تم نسخ الرسالة');
            }).catch(() => {
                showToast('تعذر نسخ الرسالة');
            });
        } else {
            showToast('النسخ غير مدعوم في هذا المتصفح');
        }
    }

