<script>
    // ============ الإعدادات العامة والمتغيرات ============
    const API_URL = "https://script.google.com/macros/s/AKfycbyR3C5uulEEmhcccBF0UXqvhhmjkKoCoHdn2b2LddLhip7IVWM9LnAwEurC8eo0AYd9pw/exec";

    let currentUser = localStorage.getItem("username") || "";
    let currentGmail = localStorage.getItem("gmail") || "";
    let currentPhotoUrl = localStorage.getItem("photourl") || "";
    let activeChatPartner = "";
    let activeChatPartnerPhoto = "";
    let chatInterval = null;
    let chatAvatarInterval = null;
    let homeInterval = null;
    let searchDebounce = null;
    let lastMessageCount = 0;

    // ---- حالة المنشورات ----
    const POSTS_PAGE_SIZE = 8;
    let postsOffset = 0;
    let postsHasMore = true;
    let postsLoading = false;

    let selectedPostType = "";
    let selectedMediaBase64 = null;
    let selectedMediaMime = null;

    let activeCommentsPostId = "";

    let selectedProfilePhotoBase64 = null;
    let selectedProfilePhotoMime = null;

    // دالة لحفظ آخر وقت قراءة لمحادثة معينة
    function saveLastReadTime(partner) {
        const readTimesKey = `${currentUser}_read_times`;
        let readTimes = JSON.parse(localStorage.getItem(readTimesKey) || "{}");
        readTimes[partner] = new Date().getTime();
        localStorage.setItem(readTimesKey, JSON.stringify(readTimes));
    }

    // دالة للحصول على آخر وقت قراءة لمحادثة معينة
    function getLastReadTime(partner) {
        const readTimesKey = `${currentUser}_read_times`;
        let readTimes = JSON.parse(localStorage.getItem(readTimesKey) || "{}");
        return readTimes[partner] || 0;
    }

    // دالة لحساب عدد الرسائل غير المقروءة من شخص معين
    function countUnreadMessages(partner, allMessages) {
        const lastReadTime = getLastReadTime(partner);
        return allMessages.filter(msg => {
            return msg.sender === partner && new Date(msg.time).getTime() > lastReadTime;
        }).length;
    }

    // تحديث دائرة صورة البروفايل الخاصة بي في الهيدر
    function updateMyAvatarDisplay() {
        const img = document.getElementById('my-avatar');
        if (!img) return;
        if (currentPhotoUrl) {
            img.src = currentPhotoUrl;
            img.style.display = 'inline-block';
        } else {
            img.style.display = 'none';
            img.removeAttribute('src');
        }
    }

    // تشغيل تلقائي عند فتح التطبيق للتحقق من الجلسة
    window.onload = function() {
        if(localStorage.getItem("isLoggedIn") === "true") {
            document.getElementById('home-title').innerText = currentUser;
            updateMyAvatarDisplay();
            navigateTo('page-home');
        }
    };

    // التنقل بين الصفحات والتحكم في الواجهة
    function navigateTo(pageId) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        const target = document.getElementById(pageId);
        if (!target) {
            console.error('navigateTo: page not found ->', pageId);
            return;
        }
        target.classList.add('active');

        if (pageId !== 'page-chat' && chatInterval) {
            clearInterval(chatInterval);
            chatInterval = null;
        }

        if (pageId !== 'page-chat' && chatAvatarInterval) {
            clearInterval(chatAvatarInterval);
            chatAvatarInterval = null;
        }

        if (pageId !== 'page-home' && homeInterval) {
            clearInterval(homeInterval);
            homeInterval = null;
        }

        if (pageId === 'page-home') {
            loadConversations();
            if (homeInterval) clearInterval(homeInterval);
            homeInterval = setInterval(() => {
                loadConversations();
            }, 4000);
        }

        if (pageId === 'page-posts') {
            // في حال تم تغيير الصورة أثناء وجودنا خارج صفحة المنشورات
            // نتأكد أن أول تحميل يعكس آخر البيانات
        }

        // إغلاق أي قائمة سياقية مفتوحة عند تغيير الصفحة
        closeAllContextMenus();
    }

    function openSearchPage() {
        document.getElementById('search-input').value = "";
        navigateTo('page-search');
        loadRandomUsers();
    }

    function showLoader(show) {
        document.getElementById('loader').style.display = show ? 'flex' : 'none';
    }

    function showToast(message) {
        const toast = document.getElementById('toast');
        toast.innerText = message;
        toast.style.display = 'block';
        setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // ضغط/تصغير الصورة قبل الإرسال لتقليل حجم البيانات (يمنع تعليق الطلب)
    function resizeImageFile(file, maxDim = 1280, quality = 0.8) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    let width = img.width;
                    let height = img.height;
                    if (width > maxDim || height > maxDim) {
                        if (width > height) {
                            height = Math.round(height * (maxDim / width));
                            width = maxDim;
                        } else {
                            width = Math.round(width * (maxDim / height));
                            height = maxDim;
                        }
                    }
                    const canvas = document.createElement('canvas');
                    canvas.width = width;
                    canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    const dataUrl = canvas.toDataURL('image/jpeg', quality);
                    resolve({
                        base64: dataUrl.split(',')[1],
                        mimeType: 'image/jpeg',
                        dataUrl: dataUrl
                    });
                };
                img.onerror = () => reject(new Error('تعذرت قراءة الصورة'));
                img.src = e.target.result;
            };
            reader.onerror = () => reject(new Error('تعذرت قراءة الملف'));
            reader.readAsDataURL(file);
        });
    }

    // إرسال طلبات الـ API مع مهلة زمنية قصوى حتى لا تدور الدائرة إلى الأبد
    async function makeRequest(data, showFullLoader = true, timeoutMs = 30000) {
        if (showFullLoader) showLoader(true);
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
        try {
            const response = await fetch(API_URL, {
                method: "POST",
                body: JSON.stringify(data),
                signal: controller.signal
            });
            clearTimeout(timeoutId);

            const rawText = await response.text();
            let resData;
            try {
                resData = JSON.parse(rawText);
            } catch (parseErr) {
                if (showFullLoader) showLoader(false);
                console.error("Invalid JSON from server (first 300 chars):", rawText.slice(0, 300));
                showToast("الخادم أرجع استجابة غير صالحة. تأكد من نشر Apps Script بصلاحية 'تنفيذ باسمي' و 'الوصول: أي شخص'");
                return null;
            }

            if (showFullLoader) showLoader(false);
            return resData;
        } catch (error) {
            clearTimeout(timeoutId);
            if (showFullLoader) showLoader(false);
            if (error.name === 'AbortError') {
                showToast("استغرق الطلب وقتًا طويلاً جدًا. تحقق من اتصالك أو جرّب ملفًا أصغر");
            } else {
                showToast("حدث خطأ في الاتصال بالخادم!");
            }
            console.error(error);
            return null;
        }
    }

    // وظيفة إنشاء حساب جديد
    async function handleRegister() {
        const username = document.getElementById('reg-username').value.trim();
        const gmail = document.getElementById('reg-gmail').value.trim();
        const password = document.getElementById('reg-password').value.trim();

        if(!username || !gmail || !password) {
            showToast("الرجاء ملء جميع الحقول");
            return;
        }

        const response = await makeRequest({
            action: "register",
            username: username,
            gmail: gmail,
            password: password
        });

        if(response) {
            if(response.status === "success") {
                showToast("تم إنشاء الحساب بنجاح!");
                navigateTo('page-login');
            } else if(response.status === "exists") {
                showToast("This Gmail already exists.");
            } else {
                showToast("حدث خطأ غير متوقع.");
            }
        }
    }

    // وظيفة تسجيل الدخول
    async function handleLogin() {
        const gmail = document.getElementById('login-gmail').value.trim();
        const password = document.getElementById('login-password').value.trim();

        if(!gmail || !password) {
            showToast("الرجاء إدخال البريد وكلمة المرور");
            return;
        }

        const response = await makeRequest({
            action: "login",
            gmail: gmail,
            password: password
        });

        if(response) {
            if(response.status === "success") {
                currentUser = response.username;
                currentGmail = gmail;
                currentPhotoUrl = response.photoUrl || "";

                localStorage.setItem("username", currentUser);
                localStorage.setItem("gmail", currentGmail);
                localStorage.setItem("photourl", currentPhotoUrl);
                localStorage.setItem("isLoggedIn", "true");

                document.getElementById('home-title').innerText = currentUser;
                updateMyAvatarDisplay();
                showToast("مرحباً " + currentUser);
                navigateTo('page-home');
            } else if(response.status === "error") {
                showToast("بيانات الاعتماد غير صحيحة.");
            }
        }
    }

    // تسجيل الخروج
    function handleLogout() {
        const readTimesKey = `${currentUser}_read_times`;
        const readTimes = localStorage.getItem(readTimesKey);
        localStorage.clear();
        if (readTimes) {
            localStorage.setItem(readTimesKey, readTimes);
        }
        currentUser = "";
        currentGmail = "";
        currentPhotoUrl = "";
        updateMyAvatarDisplay();
        if (chatInterval) { clearInterval(chatInterval); chatInterval = null; }
        if (chatAvatarInterval) { clearInterval(chatAvatarInterval); chatAvatarInterval = null; }
        if (homeInterval) { clearInterval(homeInterval); homeInterval = null; }
        navigateTo('page-splash');
    }

    // ---- تبديل اسم المستخدم ----
    function openUsernameModal() {
        document.getElementById('new-username-input').value = currentUser;
        document.getElementById('username-modal').classList.add('active');
    }

    function closeUsernameModal() {
        document.getElementById('username-modal').classList.remove('active');
    }

    async function submitUsernameChange() {
        const newUsername = document.getElementById('new-username-input').value.trim();

        if (!newUsername) {
            showToast("الرجاء إدخال اسم صالح");
            return;
        }
        if (newUsername === currentUser) {
            closeUsernameModal();
            return;
        }

        const response = await makeRequest({
            action: "update_username",
            gmail: currentGmail,
            new_username: newUsername
        });

        if (response) {
            if (response.status === "success") {
                currentUser = response.username;
                localStorage.setItem("username", currentUser);
                document.getElementById('home-title').innerText = currentUser;
                showToast("تم تبديل الاسم بنجاح");
                closeUsernameModal();
                loadConversations();
            } else if (response.status === "taken") {
                showToast("هذا الاسم مستخدم بالفعل");
            } else {
                showToast("تعذر تبديل الاسم");
            }
        }
    }

    // ---- تعديل صورة البروفايل ----
    function openPhotoModal() {
        const preview = document.getElementById('photo-preview-img');
        preview.src = currentPhotoUrl || "";
        preview.style.background = "var(--light-gray)";
        selectedProfilePhotoBase64 = null;
        selectedProfilePhotoMime = null;
        document.getElementById('photo-save-btn').disabled = true;
        document.getElementById('photo-file-input').value = "";
        document.getElementById('photo-modal').classList.add('active');
    }

    function closePhotoModal() {
        document.getElementById('photo-modal').classList.remove('active');
    }

    async function handlePhotoFileSelect(event) {
        const file = event.target.files[0];
        if (!file) return;

        try {
            showLoader(true);
            const { base64, mimeType, dataUrl } = await resizeImageFile(file, 800, 0.8);
            selectedProfilePhotoBase64 = base64;
            selectedProfilePhotoMime = mimeType;
            document.getElementById('photo-preview-img').src = dataUrl;
            document.getElementById('photo-save-btn').disabled = false;
        } catch (err) {
            showToast("تعذرت معالجة الصورة، جرّب صورة أخرى");
            console.error(err);
        } finally {
            showLoader(false);
        }
    }

    async function submitProfilePhoto() {
        if (!selectedProfilePhotoBase64) {
            showToast("الرجاء اختيار صورة");
            return;
        }

        const response = await makeRequest({
            action: "update_profile_photo",
            gmail: currentGmail,
            photoBase64: selectedProfilePhotoBase64,
            mimeType: selectedProfilePhotoMime
        });

        if (response && response.status === "success") {
            currentPhotoUrl = response.photoUrl;
            localStorage.setItem("photourl", currentPhotoUrl);
            updateMyAvatarDisplay();
            showToast("تم تحديث صورة البروفايل");
            closePhotoModal();

            // تحديث فوري لقائمة المحادثات كي تظهر الصورة الجديدة بدون انتظار الدورة التالية
            loadConversations();

            // إذا كانت صفحة المنشورات مفتوحة (أو مخزنة)، أعد تحميلها لتعكس الصورة الجديدة
            postsOffset = 0;
            postsHasMore = true;
            document.getElementById('posts-list').innerHTML = "";
            if (document.getElementById('page-posts').classList.contains('active')) {
                loadPosts(true);
            }
        } else {
            const debugMsg = response && response.debug ? (": " + response.debug) : "";
            showToast("تعذر تحديث الصورة" + debugMsg);
