<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messenger Clone</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --primary-color: #0084FF;
        --bg-color: #ffffff;
        --light-gray: #f0f2f5;
        --text-color: #050505;
        --muted-text: #65676b;
        --sent-msg: #0084FF;
        --rcv-msg: #e4e6eb;
        --badge-red: #fa383e;
        --like-red: #fa383e;
        --card-border: #e4e6eb;
    }

    [data-theme="dark"] {
        --bg-color: #18191a;
        --light-gray: #242526;
        --text-color: #e4e6eb;
        --muted-text: #b0b3b8;
        --rcv-msg: #3a3b3c;
        --card-border: #3a3b3c;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        -webkit-tap-highlight-color: transparent;
    }

    body {
        background-color: var(--light-gray);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .phone-container {
        width: 100%;
        max-width: 450px;
        height: 100vh;
        background-color: var(--bg-color);
        display: flex;
        flex-direction: column;
        position: relative;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .page {
        display: none;
        flex-direction: column;
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        background: var(--bg-color);
        animation: fadeIn 0.3s ease-in-out;
    }

    .page.active {
        display: flex;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes popIn {
        from { transform: scale(0.85); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .header {
        height: 60px;
        background: var(--bg-color);
        border-bottom: 1px solid var(--card-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        flex-shrink: 0;
    }

    .header h1 {
        font-size: 20px;
        color: var(--text-color);
        font-weight: 700;
    }

    .header-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .header-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--light-gray);
        flex-shrink: 0;
        display: none;
    }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    .icon-btn {
        background: none;
        border: none;
        color: var(--primary-color);
        cursor: pointer;
        font-size: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.15s;
    }

    .icon-btn:active { transform: scale(0.85); }

    .auth-container {
        padding: 30px 24px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
        align-items: center;
    }

    .app-logo {
        font-size: 80px;
        color: var(--primary-color);
        margin-bottom: 20px;
    }

    .app-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 40px;
        color: var(--text-color);
    }

    .input-group {
        width: 100%;
        margin-bottom: 16px;
    }

    .input-group input, .input-group textarea {
        width: 100%;
        padding: 14px 16px;
        border-radius: 12px;
        border: 1px solid #ccc;
        background: var(--light-gray);
        font-size: 16px;
        outline: none;
        transition: 0.2s;
        text-align: right;
        color: var(--text-color);
        font-family: inherit;
    }

    .input-group textarea {
        resize: none;
        min-height: 90px;
    }

    .input-group input:focus, .input-group textarea:focus {
        border-color: var(--primary-color);
        background: var(--bg-color);
        box-shadow: 0 0 0 2px rgba(0,132,255,0.2);
    }

    .btn {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: none;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        margin-top: 10px;
    }

    .btn-primary {
        background-color: var(--primary-color);
        color: white;
    }

    .btn-secondary {
        background-color: var(--light-gray);
        color: var(--text-color);
    }

    .btn:active {
        transform: scale(0.98);
    }

    .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .auth-switch {
        margin-top: 20px;
        color: var(--primary-color);
        cursor: pointer;
        font-weight: 600;
    }

    .search-container {
        padding: 10px 16px;
        display: flex;
        gap: 8px;
        background: var(--bg-color);
        flex-shrink: 0;
    }

    .search-box {
        flex: 1;
        display: flex;
        align-items: center;
        background: var(--light-gray);
        border-radius: 20px;
        padding: 0 12px;
    }

    .search-box input {
        width: 100%;
        border: none;
        background: transparent;
        padding: 8px;
        outline: none;
        font-size: 15px;
        text-align: right;
        color: var(--text-color);
    }

    .scroll-body {
        flex: 1;
        overflow-y: auto;
    }

    .section-label {
        padding: 14px 16px 6px;
        font-size: 13px;
        font-weight: 700;
        color: var(--muted-text);
    }

    .list-container {
        padding: 0 8px;
    }

    .list-item {
        display: flex;
        align-items: center;
        padding: 12px 8px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.2s;
    }

    .list-item:hover {
        background-color: var(--light-gray);
    }

    .avatar-wrap {
        position: relative;
        margin-left: 12px;
        flex-shrink: 0;
    }

    .avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        overflow: hidden;
        object-fit: cover;
    }

    .avatar-sm {
        width: 38px;
        height: 38px;
        font-size: 18px;
    }

    .unread-badge {
        background: var(--badge-red);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        min-width: 20px;
        height: 20px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 6px;
        line-height: 1;
    }

    .item-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        margin-right: 4px;
        min-width: 34px;
        flex-shrink: 0;
    }

    .item-time {
        font-size: 12px;
        color: var(--muted-text);
        white-space: nowrap;
    }

    .item-details {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .item-name {
        font-weight: 600;
        font-size: 16px;
        color: var(--text-color);
    }

    .item-meta {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: var(--muted-text);
        margin-top: 2px;
    }

    .item-msg {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        background: var(--bg-color);
    }

    .msg-wrapper {
        display: flex;
        width: 100%;
    }

    .msg-wrapper.sent {
        justify-content: flex-start;
    }

    .msg-wrapper.received {
        justify-content: flex-end;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 10px 16px;
        border-radius: 18px;
        font-size: 15px;
        line-height: 1.4;
        word-wrap: break-word;
        user-select: none;
        -webkit-user-select: none;
    }

    .sent .msg-bubble {
        background-color: var(--sent-msg);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .received .msg-bubble {
        background-color: var(--rcv-msg);
        color: var(--text-color);
        border-bottom-left-radius: 4px;
    }

    /* ===== رسائل صوتية داخل فقاعة الشات ===== */
    .audio-msg-bubble {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 190px;
    }
    .audio-play-btn {
        background: none;
        border: none;
        color: inherit;
        font-size: 28px;
        cursor: pointer;
        padding: 0;
        display: flex;
        flex-shrink: 0;
    }
    .audio-progress-track {
        flex: 1;
        height: 4px;
        background: rgba(255,255,255,0.4);
        border-radius: 2px;
        overflow: hidden;
    }
    .received .audio-progress-track {
        background: rgba(0,0,0,0.15);
    }
    .audio-progress-fill {
        height: 100%;
        width: 0%;
        background: currentColor;
    }
    .audio-duration {
        font-size: 12px;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .hidden-audio-el { display: none; }

    .chat-input-bar {
        padding: 12px 16px;
        border-top: 1px solid var(--card-border);
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--bg-color);
    }

    .chat-input-bar input {
        flex: 1;
        background: var(--light-gray);
        border: none;
        padding: 12px 16px;
        border-radius: 20px;
        outline: none;
        font-size: 15px;
        text-align: right;
        color: var(--text-color);
    }

    /* ===== شريط تسجيل الصوت وشريط معاينة التسجيل ===== */
    .voice-recording-bar, .voice-preview-bar {
        padding: 12px 16px;
        border-top: 1px solid var(--card-border);
        display: none;
        align-items: center;
        gap: 14px;
        background: var(--bg-color);
    }
    .recording-indicator {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: var(--text-color);
        font-weight: 600;
        font-size: 15px;
    }
    .rec-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--badge-red);
        animation: recBlink 1s infinite;
        flex-shrink: 0;
    }
    @keyframes recBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
    .voice-preview-duration {
        flex: 1;
        text-align: center;
        color: var(--text-color);
        font-weight: 600;
    }

    .toast {
        position: absolute;
        bottom: 80px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 10px 20px;
        border-radius: 20px;
        font-size: 14px;
        display: none;
        z-index: 2000;
        white-space: nowrap;
    }

    .loader {
        display: none;
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(255,255,255,0.7);
        z-index: 999;
        justify-content: center;
        align-items: center;
    }
    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid var(--light-gray);
        border-top: 4px solid var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    /* نوافذ منبثقة عامة */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1500;
    }
    .modal-overlay.active {
        display: flex;
    }
    .modal-box {
        background: var(--bg-color);
        border-radius: 16px;
        padding: 24px;
        width: 85%;
        max-width: 340px;
        animation: popIn 0.2s ease-out;
    }
    .modal-box h3 {
        font-size: 18px;
        margin-bottom: 16px;
        color: var(--text-color);
    }

    /* ===== قائمة سياقية عائمة (تُستخدم للضغط المطول على الرسائل ولقائمة المنشورات) ===== */
    .context-menu {
        position: fixed;
        display: none;
        background: var(--bg-color);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.28);
        z-index: 3000;
        min-width: 180px;
        overflow: hidden;
    }
    .context-menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 13px 16px;
        background: none;
        border: none;
        text-align: right;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-color);
        cursor: pointer;
    }
    .context-menu-item:active { background: var(--light-gray); }
    .context-menu-danger { color: var(--badge-red); }
    .context-menu-danger .material-icons { color: var(--badge-red); }
    .context-menu-overlay-catcher {
        position: fixed;
        inset: 0;
        z-index: 2999;
        display: none;
    }

    /* أزرار عائمة (FAB) */
    .fab {
        position: absolute;
        bottom: 24px;
        right: 24px;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: var(--primary-color);
        color: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        box-shadow: 0 4px 14px rgba(0,132,255,0.4);
        cursor: pointer;
        z-index: 50;
        transition: transform 0.15s ease;
    }
    .fab:active { transform: scale(0.9); }

    /* اختيار نوع المنشور */
    .post-type-choice {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 8px;
    }
    .post-type-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 12px;
        background: var(--light-gray);
        border: none;
        font-size: 16px;
        font-weight: 600;
        color: var(--text-color);
        cursor: pointer;
        transition: 0.15s;
    }
    .post-type-btn:active { transform: scale(0.97); }
    .post-type-btn .material-icons { color: var(--primary-color); font-size: 26px; }

    /* منشورات - بطاقة */
    .post-card {
        border-bottom: 8px solid var(--light-gray);
        padding-bottom: 6px;
        background: var(--bg-color);
    }
    .post-header {
        display: flex;
        align-items: center;
        padding: 12px 16px;
    }
    .post-header-info {
        flex: 1;
        min-width: 0;
    }
    .post-username {
        font-weight: 700;
        font-size: 15px;
        color: var(--text-color);
    }
    .post-time {
        font-size: 12px;
        color: var(--muted-text);
    }
    .post-menu-btn {
        background: none;
        border: none;
        color: var(--muted-text);
        font-size: 22px;
        cursor: pointer;
        padding: 6px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .post-caption {
        padding: 0 16px 10px;
        font-size: 15px;
        color: var(--text-color);
        line-height: 1.5;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .post-media {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        background: #000;
        display: block;
    }
    .post-text-only {
        margin: 0 16px 12px;
        padding: 18px;
        background: var(--light-gray);
        border-radius: 14px;
        font-size: 17px;
        font-weight: 500;
        color: var(--text-color);
        line-height: 1.6;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .post-actions {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 6px 16px 4px;
    }
    .post-action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        font-size: 14px;
        font-weight: 600;
        color: var(--muted-text);
        cursor: pointer;
        padding: 6px 4px;
    }
    .post-action-btn .material-icons {
        font-size: 22px;
        transition: transform 0.15s;
    }
    .post-action-btn:active .material-icons { transform: scale(1.3); }
    .post-action-btn.liked { color: var(--like-red); }
    .post-action-btn.liked .material-icons { color: var(--like-red); }

    .media-preview {
        width: 100%;
        max-height: 220px;
        object-fit: contain;
        border-radius: 12px;
        margin-bottom: 12px;
        background: var(--light-gray);
    }
    .file-picker-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px;
        border-radius: 12px;
        border: 2px dashed #bbb;
        background: var(--light-gray);
        color: var(--muted-text);
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 16px;
    }

    /* تعليقات */
    .comment-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 16px;
    }
    .comment-bubble {
        background: var(--light-gray);
        border-radius: 14px;
        padding: 8px 14px;
        flex: 1;
    }
    .comment-username {
        font-weight: 700;
        font-size: 13px;
        color: var(--text-color);
    }
    .comment-text {
        font-size: 14px;
        color: var(--text-color);
        margin-top: 2px;
        word-wrap: break-word;
    }
    .comment-time {
        font-size: 11px;
        color: var(--muted-text);
        margin-top: 4px;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--muted-text);
    }
    .empty-state .material-icons {
        font-size: 48px;
        opacity: 0.5;
        margin-bottom: 8px;
        display: block;
    }

    .load-more-btn {
        display: block;
        margin: 12px auto;
        padding: 10px 20px;
        border-radius: 20px;
        border: none;
        background: var(--light-gray);
        color: var(--primary-color);
        font-weight: 600;
        cursor: pointer;
    }

    .profile-photo-preview-wrap {
        display: flex;
        justify-content: center;
        margin-bottom: 16px;
    }
    .profile-photo-preview {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--light-gray);
    }
</style>
</head>
<body>
<div class="phone-container">
    <div class="loader" id="loader"><div class="spinner"></div></div>
    <div class="toast" id="toast"></div>

    <!-- طبقة شفافة لالتقاط الضغط خارج القائمة السياقية وإغلاقها -->
    <div class="context-menu-overlay-catcher" id="context-menu-catcher" onclick="closeAllContextMenus()"></div>
    <!-- قائمة سياقية عائمة موحّدة: تُستخدم لكل من (الضغط المطول على رسالة) و(قائمة نقاط المنشور) -->
    <div class="context-menu" id="message-context-menu"></div>

    <!-- نافذة تبديل اسم المستخدم -->
    <div class="modal-overlay" id="username-modal">
        <div class="modal-box">
            <h3>تبديل اسم المستخدم</h3>
            <div class="input-group"><input type="text" id="new-username-input" placeholder="الاسم الجديد"></div>
            <button class="btn btn-primary" onclick="submitUsernameChange()">حفظ</button>
            <button class="btn btn-secondary" onclick="closeUsernameModal()">إلغاء</button>
        </div>
    </div>

    <!-- نافذة تعديل صورة البروفايل -->
    <div class="modal-overlay" id="photo-modal">
        <div class="modal-box">
            <h3>تعديل صورة البروفايل</h3>
            <div class="profile-photo-preview-wrap">
                <img class="profile-photo-preview" id="photo-preview-img" src="">
            </div>
            <label class="file-picker-btn" style="margin-bottom:12px;">
                <span class="material-icons">add_a_photo</span>
                اختيار صورة
                <input type="file" accept="image/*" id="photo-file-input" style="display:none" onchange="handlePhotoFileSelect(event)">
            </label>
            <button class="btn btn-primary" id="photo-save-btn" onclick="submitProfilePhoto()" disabled>حفظ</button>
            <button class="btn btn-secondary" onclick="closePhotoModal()">إلغاء</button>
        </div>
    </div>

    <!-- نافذة اختيار نوع المنشور -->
    <div class="modal-overlay" id="post-type-modal">
        <div class="modal-box">
            <h3>إنشاء منشور جديد</h3>
            <div class="post-type-choice">
                <button class="post-type-btn" onclick="choosePostType('image')">
                    <span class="material-icons">photo_camera</span> نشر صورة
                </button>
                <button class="post-type-btn" onclick="choosePostType('video')">
                    <span class="material-icons">videocam</span> نشر فيديو
                </button>
                <button class="post-type-btn" onclick="choosePostType('text')">
                    <span class="material-icons">notes</span> نشر نص
                </button>
            </div>
            <button class="btn btn-secondary" onclick="closePostTypeModal()">إلغاء</button>
        </div>
    </div>

