    // صفحة المحادثة وإرسال واستقبال الرسائل
    async function openChat(partnerName, partnerPhoto) {
        activeChatPartner = partnerName;
        activeChatPartnerPhoto = partnerPhoto || "";

        document.getElementById('chat-target-name').innerText = partnerName;

        const chatAvatarImg = document.getElementById('chat-target-avatar');
        if (activeChatPartnerPhoto) {
            chatAvatarImg.src = activeChatPartnerPhoto;
            chatAvatarImg.style.display = 'inline-block';
        } else {
            chatAvatarImg.style.display = 'none';
            chatAvatarImg.removeAttribute('src');
        }

        document.getElementById('chat-messages-container').innerHTML = "";
        lastMessageCount = 0;

        // التأكد من أن شريط الإدخال العادي هو الظاهر (وليس شريط تسجيل متبقٍ من محادثة سابقة)
        resetVoiceUiState();

        navigateTo('page-chat');

